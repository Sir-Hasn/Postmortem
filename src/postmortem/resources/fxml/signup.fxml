<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<AnchorPane
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="postmortem.controller.SignupController"
    stylesheets="@../css/styles.css"
    prefWidth="900" prefHeight="600"
    styleClass="root">

    <!-- Left decorative panel -->
    <VBox
        AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
        AnchorPane.leftAnchor="0"
        prefWidth="420"
        styleClass="login-left-panel"
        alignment="CENTER">
        <padding><Insets top="60" bottom="60" left="50" right="50"/></padding>

        <Label text="POSTMORTEM" styleClass="brand-title"/>
        <Label text="// bug tracking journal" styleClass="brand-subtitle" style="-fx-padding: 6 0 0 0;"/>

        <VBox spacing="0" style="-fx-padding: 48 0 0 0;">
            <Label text="&gt; log every failure." styleClass="tagline"/>
            <Label text="&gt; document every fix." styleClass="tagline"/>
            <Label text="&gt; never repeat yourself." styleClass="tagline"/>
        </VBox>

        <Label text="version 1.0.0" styleClass="label-muted"
               style="-fx-padding: 40 0 0 0; -fx-font-size: 11px;"/>
    </VBox>

    <!-- Right signup form -->
    <VBox
        AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
        AnchorPane.rightAnchor="0"
        prefWidth="480"
        alignment="CENTER"
        styleClass="login-right-panel">
        <padding><Insets top="60" bottom="60" left="60" right="60"/></padding>

        <Label text="Create account" styleClass="form-heading"/>
        <Label text="Start your bug journal" styleClass="label-muted" style="-fx-padding: 4 0 32 0;"/>

        <Label text="USERNAME" styleClass="field-label"/>
        <TextField
            fx:id="usernameField"
            promptText="choose a username"
            styleClass="input-field"
            style="-fx-padding: 6 0 20 0;"/>

        <Label text="PASSWORD" styleClass="field-label"/>
        <PasswordField
            fx:id="passwordField"
            promptText="create a password"
            styleClass="input-field"
            style="-fx-padding: 6 0 20 0;"/>

        <Label text="CONFIRM PASSWORD" styleClass="field-label"/>
        <PasswordField
            fx:id="confirmPasswordField"
            promptText="repeat your password"
            styleClass="input-field"
            style="-fx-padding: 6 0 8 0;"/>

        <Label fx:id="errorLabel" styleClass="label-error" text="" style="-fx-padding: 0 0 16 0;"/>

        <Button
            text="CREATE ACCOUNT"
            onAction="#onSignup"
            styleClass="btn-primary"
            maxWidth="Infinity"
            style="-fx-padding: 12 0 0 0;"/>

        <HBox alignment="CENTER" spacing="12" style="-fx-padding: 28 0 28 0;">
            <Separator HBox.hgrow="ALWAYS"/>
            <Label text="or" styleClass="label-muted"/>
            <Separator HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox alignment="CENTER" spacing="6">
            <Label text="Already have an account?" styleClass="label-muted"/>
            <Button text="Sign in" onAction="#onGoToLogin" styleClass="btn-link"/>
        </HBox>
    </VBox>
</AnchorPane>
