<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<AnchorPane
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="postmortem.controller.SignupController"
    stylesheets="@../css/styles.css"
    prefWidth="900" prefHeight="600"
    styleClass="root">

    <!-- Left decorative panel -->
    <VBox
        AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
        AnchorPane.leftAnchor="0"
        prefWidth="420"
        styleClass="login-left-panel"
        alignment="CENTER">
        <padding><Insets top="60" bottom="60" left="50" right="50"/></padding>

        <Label text="POSTMORTEM" styleClass="brand-title"/>
        <Label text="// bug tracking journal" styleClass="brand-subtitle" style="-fx-padding: 6 0 0 0;"/>

        <VBox spacing="0" style="-fx-padding: 48 0 0 0;">
            <Label text="&gt; log every failure." styleClass="tagline"/>
            <Label text="&gt; document every fix." styleClass="tagline"/>
            <Label text="&gt; never repeat yourself." styleClass="tagline"/>
        </VBox>

        <Label text="version 1.0.0" styleClass="label-muted"
               style="-fx-padding: 40 0 0 0; -fx-font-size: 11px;"/>
    </VBox>

    <!-- Right signup form -->
    <VBox
        AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
        AnchorPane.rightAnchor="0"
        AnchorPane.leftAnchor="420"
        alignment="CENTER"
        styleClass="login-right-panel">
        <padding><Insets top="60" bottom="60" left="60" right="60"/></padding>

        <VBox alignment="CENTER_LEFT" spacing="8" prefWidth="430" maxWidth="430">
            <Label text="Create account" styleClass="form-heading"/>
            <Label text="Start your bug journal" styleClass="label-muted" style="-fx-padding: 4 0 24 0;"/>

            <Label text="USERNAME" styleClass="field-label"/>
            <TextField
                fx:id="usernameField"
                promptText="Choose a username"
                styleClass="input-field"
                prefWidth="430"
                maxWidth="430"/>

            <Label text="PASSWORD" styleClass="field-label" style="-fx-padding: 10 0 0 0;"/>
            <StackPane prefWidth="430" maxWidth="430">
                <PasswordField
                    fx:id="passwordField"
                    promptText="Create a password"
                    styleClass="input-field"
                    prefWidth="430"
                    maxWidth="430"/>
                <TextField
                    fx:id="passwordVisibleField"
                    promptText="Create a password"
                    styleClass="input-field"
                    prefWidth="430"
                    maxWidth="430"
                    visible="false"
                    managed="false"/>
            </StackPane>

            <Label text="CONFIRM PASSWORD" styleClass="field-label" style="-fx-padding: 10 0 0 0;"/>
            <StackPane prefWidth="430" maxWidth="430">
                <PasswordField
                    fx:id="confirmPasswordField"
                    promptText="Repeat your password"
                    styleClass="input-field"
                    prefWidth="430"
                    maxWidth="430"/>
                <TextField
                    fx:id="confirmPasswordVisibleField"
                    promptText="Repeat your password"
                    styleClass="input-field"
                    prefWidth="430"
                    maxWidth="430"
                    visible="false"
                    managed="false"/>
            </StackPane>

            <CheckBox fx:id="showPasswordCheck" text="Show passwords" onAction="#onTogglePasswordVisibility"
                      styleClass="label-muted" style="-fx-padding: 2 0 0 0;"/>

            <Label fx:id="errorLabel" styleClass="label-error" text="" prefWidth="430" maxWidth="430" style="-fx-padding: 2 0 8 0;"/>

            <Button
                text="CREATE ACCOUNT"
                onAction="#onSignup"
                styleClass="btn-primary"
                prefWidth="430"
                maxWidth="430"/>

            <HBox alignment="CENTER" spacing="12" style="-fx-padding: 22 0 16 0;" prefWidth="430" maxWidth="430">
                <Separator HBox.hgrow="ALWAYS"/>
                <Label text="or" styleClass="label-muted"/>
                <Separator HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox alignment="CENTER" spacing="6" prefWidth="430" maxWidth="430">
                <Label text="Already have an account?" styleClass="label-muted"/>
                <Button text="Sign in" onAction="#onGoToLogin" styleClass="btn-link"/>
            </HBox>
        </VBox>
    </VBox>

</AnchorPane>
