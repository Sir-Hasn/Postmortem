<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="postmortem.controller.BugEntryDetailController"
    stylesheets="@../css/styles.css"
    prefWidth="1100" prefHeight="680"
    styleClass="root">

    <!-- ── TOP NAVBAR ── -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="0" bottom="0" left="24" right="24"/></padding>
            <Label text="POSTMORTEM" styleClass="nav-brand"/>
            <Label text="//" styleClass="label-muted"/>
            <Label text="Entry detail" styleClass="nav-page"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Back" onAction="#onBack" styleClass="btn-ghost"/>
        </HBox>
    </top>

    <!-- ── CONTENT ── -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox styleClass="main-content" spacing="0">
                <padding><Insets top="36" bottom="36" left="200" right="200"/></padding>

                <!-- Title + action row -->
                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 8 0;">
                    <TextField fx:id="titleField"
                               promptText="Bug title"
                               styleClass="input-field"
                               HBox.hgrow="ALWAYS"/>
                </HBox>
                <Label fx:id="titleErrorLabel" styleClass="label-error" text="" style="-fx-padding: 0 0 12 0;"/>

                <!-- Meta row: status badge + timestamps -->
                <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 0 0 32 0;">
                    <Label text="Status" styleClass="label-muted"/>
                    <ComboBox fx:id="statusCombo" prefWidth="180" styleClass="combo-field"/>
                    <Label fx:id="createdLabel" text="Created:" styleClass="label-muted"/>
                    <Label fx:id="updatedLabel" text="Updated:" styleClass="label-muted"/>
                </HBox>

                <!-- Tags -->
                <Label text="TAGS" styleClass="field-label"/>
                <TextField fx:id="tagsField"
                           promptText="Comma-separated tags"
                           styleClass="input-field"
                           style="-fx-padding: 6 0 6 0;"/>
                <Label fx:id="tagsErrorLabel" styleClass="label-error" text="" style="-fx-padding: 0 0 12 0;"/>

                <!-- Error message -->
                <Label text="ERROR MESSAGE" styleClass="field-label"/>
                <TextArea fx:id="errorMessageArea"
                          styleClass="detail-area"
                          editable="true"
                          wrapText="true"
                          prefRowCount="4"
                          style="-fx-padding: 6 0 6 0;"
                          text=""/>
                <Label fx:id="errorMessageErrorLabel" styleClass="label-error" text="" style="-fx-padding: 0 0 12 0;"/>

                <!-- Context -->
                <Label text="CONTEXT" styleClass="field-label"/>
                <TextArea fx:id="contextArea"
                          styleClass="detail-area"
                          editable="true"
                          wrapText="true"
                          prefRowCount="3"
                          style="-fx-padding: 6 0 6 0;"
                          text=""/>
                <Label fx:id="contextErrorLabel" styleClass="label-error" text="" style="-fx-padding: 0 0 12 0;"/>

                <!-- Solution -->
                <Label text="SOLUTION" styleClass="field-label"/>
                <TextArea fx:id="solutionArea"
                          styleClass="detail-area"
                          editable="true"
                          wrapText="true"
                          prefRowCount="3"
                          style="-fx-padding: 6 0 6 0;"
                          text=""/>
                <Label fx:id="solutionErrorLabel" styleClass="label-error" text="" style="-fx-padding: 0 0 12 0;"/>

                <Label fx:id="errorLabel" styleClass="label-error" text="" style="-fx-padding: 0 0 12 0;"/>

                <!-- Divider -->
                <Separator style="-fx-padding: 0 0 28 0;"/>

                <!-- Action buttons -->
                <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 24 0 0 0;">
                    <Button text="DELETE" onAction="#onDelete" styleClass="btn-danger"/>
                    <Button fx:id="toggleStatusBtn"
                            text="MARK AS RESOLVED"
                            onAction="#onToggleStatus"
                            styleClass="btn-outline"/>
                    <Button text="SAVE CHANGES" onAction="#onSaveChanges" styleClass="btn-primary"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
